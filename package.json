{
  "name": "@theclawlab/xgw",
  "type": "module",
  "version": "2.1.0",
  "description": "xgw - communication gateway daemon & CLI for TheClaw",
  "bin": {
    "xgw": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "release:local": "npm run build && npm link",
    "release:public": "npm test && npm run build && npm publish --access public",
    "release:public:skip-test": "npm run build && npm publish --access public"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "USAGE.md"
  ],
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  }
}
